{
  "name": "@sivraj/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/index.ts",
    "memory:diagnose": "node scripts/diagnose-memory.mjs",
    "onboarding:reset": "tsx scripts/reset-onboarding.mjs",
    "telegram:check": "node scripts/telegram-webhook.mjs check-env",
    "telegram:commands:get": "node scripts/telegram-webhook.mjs commands:get",
    "telegram:commands:set": "node scripts/telegram-webhook.mjs commands:set",
    "telegram:get-me": "node scripts/telegram-webhook.mjs get-me",
    "telegram:health": "node scripts/telegram-webhook.mjs health",
    "telegram:poll": "node scripts/telegram-webhook.mjs poll",
    "telegram:profile:get": "node scripts/telegram-webhook.mjs profile:get",
    "telegram:profile:set": "node scripts/telegram-webhook.mjs profile:set",
    "telegram:production:setup": "node scripts/telegram-webhook.mjs production:setup",
    "telegram:webhook:delete": "node scripts/telegram-webhook.mjs delete",
    "telegram:webhook:info": "node scripts/telegram-webhook.mjs info",
    "telegram:webhook:set": "node scripts/telegram-webhook.mjs set",
    "test": "vitest run src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@mysten/sui": "^2.16.3",
    "@sivraj/auth": "workspace:*",
    "@sivraj/config": "workspace:*",
    "@sivraj/core": "workspace:*",
    "@sivraj/crypto-seal": "workspace:*",
    "@sivraj/db": "workspace:*",
    "@sivraj/ingestion": "workspace:*",
    "@sivraj/intelligence": "workspace:*",
    "@sivraj/llm": "workspace:*",
    "@sivraj/private-memory-reader": "workspace:*",
    "@sivraj/queue": "workspace:*",
    "@sivraj/retrieval": "workspace:*",
    "@sivraj/storage-walrus": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "pg": "^8.20.0",
    "tsx": "^4.22.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "typescript": "~6.0.3",
    "vitest": "^4.1.6"
  }
}
