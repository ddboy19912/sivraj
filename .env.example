# App
NODE_ENV=development
APP_URL=http://localhost:5173
API_URL=http://127.0.0.1:3000
VITE_API_URL=http://127.0.0.1:3000

# API
API_HOST=0.0.0.0
API_PORT=3000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
DATABASE_URL=postgresql://sivraj:sivraj@localhost:5432/sivraj

# Queue / Worker
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=2

# LLM
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=
EMBEDDING_MODEL=

# Speech to text
SPEECH_TO_TEXT_PROVIDER=openai
SPEECH_TO_TEXT_API_KEY=
SPEECH_TO_TEXT_MODEL=gpt-4o-mini-transcribe

# Walrus
WALRUS_NETWORK=testnet
WALRUS_EPOCHS=5
WALRUS_DELETABLE=false
WALRUS_UPLOAD_RELAY_URL=https://upload-relay.testnet.walrus.space
WALRUS_UPLOAD_RELAY_TIP_MAX_MIST=1000

# Seal
SEAL_PACKAGE_ID=
SEAL_POLICY_ID=
SEAL_KEY_SERVERS=
SEAL_THRESHOLD=1

# Sui
SUI_NETWORK=testnet
SUI_RPC_URL=
SUI_PRIVATE_KEY=

# Auth
JWT_SECRET=
TOKEN_ISSUER=sivraj

# Observability
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=
