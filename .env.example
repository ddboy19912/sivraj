# App
NODE_ENV=development
APP_URL=http://localhost:5173
API_URL=http://127.0.0.1:3000
VITE_API_URL=http://127.0.0.1:3000
VITE_SUI_NETWORK=testnet
VITE_SUI_RPC_URL=https://fullnode.testnet.sui.io:443
VITE_SEAL_PACKAGE_ID=
VITE_SEAL_POLICY_ID=
VITE_SEAL_KEY_SERVERS=
VITE_SEAL_THRESHOLD=1

# API
API_HOST=0.0.0.0
API_PORT=3000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MEMORY_SEARCH_SHORTLIST_LIMIT=25
MEMORY_SEARCH_FALLBACK_LIMIT=20
MEMORY_SEARCH_DECRYPT_CONCURRENCY=3
MEMORY_SEARCH_DECRYPT_EVIDENCE_LIMIT=3

# Database
DATABASE_URL=postgresql://sivraj:sivraj@localhost:5432/sivraj

# Queue / Worker
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=2
ARTIFACT_RECONCILE_INTERVAL_MS=60000
ARTIFACT_RECONCILE_LIMIT=25
TRANSIENT_CIPHERTEXT_MAX_BYTES=2097152
INTELLIGENCE_CHUNK_CHARS=18000
INTELLIGENCE_CHUNK_CONCURRENCY=2
CANDIDATE_MEMORY_ARCHIVE_CONCURRENCY=1
CANDIDATE_MEMORY_ARCHIVE_RECONCILE_INTERVAL_MS=60000
CANDIDATE_MEMORY_ARCHIVE_RECONCILE_LIMIT=25
CONNECTOR_RECONCILE_INTERVAL_MS=60000
CONNECTOR_RECONCILE_LIMIT=25
CONNECTOR_SYNC_CONCURRENCY=1

# Connectors
NOTION_API_TOKEN=
SLACK_BOT_TOKEN=
GMAIL_ACCESS_TOKEN=
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_DRIVE_ACCESS_TOKEN=
MICROSOFT_GRAPH_ACCESS_TOKEN=

# LLM
LLM_PROVIDER=openrouter
LLM_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api
LLM_MODEL=google/gemini-2.5-flash-lite
LLM_REQUEST_TIMEOUT_MS=30000
LLM_CREDENTIAL_ENCRYPTION_KEY=
EMBEDDING_PROVIDER=openrouter
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://openrouter.ai/api
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_REQUEST_TIMEOUT_MS=30000

# Speech to text
SPEECH_TO_TEXT_BASE_URL=https://api.cartesia.ai
SPEECH_TO_TEXT_MODEL=ink-whisper

# Voice synthesis
VOICE_SERVICE_KIND=cartesia
VOICE_SERVICE_URL=http://127.0.0.1:7860
VOICE_SERVICE_API_KEY=
VOICE_SERVICE_TIMEOUT_MS=30000
CARTESIA_API_KEY=
CARTESIA_VERSION=2026-03-01
CARTESIA_MODEL_ID=sonic-3.5
CARTESIA_DEFAULT_VOICE_ID=
HF_TOKEN=
CARTESIA_REALTIME_STT_MODEL=ink-2
CARTESIA_STT_SAMPLE_RATE=48000
CARTESIA_STT_TOKEN_EXPIRES_IN_SECONDS=60

# Walrus
WALRUS_NETWORK=testnet
WALRUS_EPOCHS=5
WALRUS_DELETABLE=false
WALRUS_MIN_WRITE_BALANCE_MIST=200000000
WALRUS_UPLOAD_RELAY_URL=https://upload-relay.testnet.walrus.space
WALRUS_UPLOAD_RELAY_TIP_MAX_MIST=1000
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# Seal
SEAL_PACKAGE_ID=
SEAL_POLICY_ID=
SEAL_KEY_SERVERS=
SEAL_THRESHOLD=1

# Sui
SUI_NETWORK=testnet
SUI_RPC_URL=
SUI_PRIVATE_KEY=

# Auth
JWT_SECRET=
TOKEN_ISSUER=sivraj

# MCP / Coding Agent Integration
SIVRAJ_API_URL=http://127.0.0.1:3000
SIVRAJ_TWIN_ID=
SIVRAJ_TOKEN=
SIVRAJ_PROJECT_NAME=sivraj
SIVRAJ_PROJECT_ID=
SIVRAJ_INCLUDE_CANDIDATES=true
SIVRAJ_MAX_ITEMS_PER_SECTION=12

# Observability
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=

# Optional API runtime
PORT=3000
VOICE_PREVIEW_ASSET_DIR=

# Optional dev auth
DEV_AUTH_SUB=
DEV_AUTH_SCOPES=
DEV_AUTH_TWIN_ID=
DEV_AUTH_WALLET_ADDRESS=
DEV_AUTH_EXPIRES_IN=

# Optional chat tuning
CHAT_RECENT_RAW_MESSAGE_LIMIT=48
CHAT_TITLE_TIMEOUT_MS=30000
CHAT_CONTEXT_RESOLVE_TIMEOUT_MS=30000
CHAT_CURRENT_TRUTH_CONTEXT_LIMIT=12
CHAT_TURN_PLANNING_MEMORY_HINT_LIMIT=40
CHAT_MEMORY_INTAKE_TIMEOUT_MS=30000
CHAT_MEMORY_INTAKE_MAX_RETRIES=1
CHAT_MEMORY_DECRYPT_TIMEOUT_MS=30000
CHAT_MEMORY_PLAINTEXT_CACHE_TTL_MS=600000
CHAT_CANDIDATE_MEMORY_DECRYPT_LIMIT=8
CHAT_CANDIDATE_MEMORY_DECRYPT_TIMEOUT_MS=30000
CHAT_PROVIDER_CONFIG_CACHE_TTL_MS=5000
CHAT_CORE_COMMS_CACHE_TTL_MS=30000
CHAT_VOICE_REPLY_TIMEOUT_MS=30000

# Optional private context runtime
CONTEXT_RUNTIME_ENABLED=true
CONTEXT_RUNTIME_SHADOW_MODE=false
CONTEXT_WARMUP_ENABLED=true
CONTEXT_WARMUP_CONCURRENCY=1
PRIVATE_MEMORY_CIPHERTEXT_CACHE_ENABLED=true
PRIVATE_MEMORY_CIPHERTEXT_CACHE_TTL_MS=86400000
PRIVATE_MEMORY_CIPHERTEXT_CACHE_MAX_BYTES=10485760

# Optional document chat retrieval tuning
CHAT_DOCUMENT_RECENT_LIMIT=3
CHAT_RETRIEVAL_PLAN_TIMEOUT_MS=30000
CHAT_DOCUMENT_PASSAGE_LIMIT=4
CHAT_DOCUMENT_TARGET_PAGE_LIMIT=8
CHAT_DOCUMENT_DIRECT_PAGE_LIMIT=16
CHAT_DOCUMENT_GLOBAL_SCAN_TIMEOUT_MS=30000
CHAT_DOCUMENT_GLOBAL_SCAN_CHAR_LIMIT=20000
CHAT_DOCUMENT_GLOBAL_SCAN_MAX_BATCHES=80
CHAT_DOCUMENT_GLOBAL_SCAN_CONCURRENCY=2
CHAT_DOCUMENT_GLOBAL_SCAN_PAGE_BATCH=6
CHAT_DOCUMENT_GLOBAL_SCAN_PAGE_LIMIT=2000
CHAT_DOCUMENT_CHUNK_ROW_LIMIT=5000
CHAT_DOCUMENT_EMBEDDING_CANDIDATE_LIMIT=48
CHAT_DOCUMENT_QUERY_EMBEDDING_TIMEOUT_MS=30000
CHAT_DOCUMENT_DECRYPT_TIMEOUT_MS=30000
CHAT_DOCUMENT_STRUCTURE_EXTRACTION_TIMEOUT_MS=30000
CHAT_DOCUMENT_CONTEXT_CACHE_TTL_MS=600000

# Optional text to speech provider config
TEXT_TO_SPEECH_PROVIDER=
TEXT_TO_SPEECH_API_KEY=
TEXT_TO_SPEECH_BASE_URL=
TEXT_TO_SPEECH_MODEL=
GOOGLE_API_KEY=

# Optional worker startup and maintenance
WORKER_DRAIN_EXISTING_ON_BOOT=true
WORKER_BOOT_DRAIN_LIMIT=100
WEEKLY_REFLECTION_CONCURRENCY=1
MEMORY_RENEWAL_RECONCILE_INTERVAL_MS=21600000
MEMORY_RENEWAL_RECONCILE_LIMIT=25

# Optional Walrus renewal scripts
WALRUS_CURRENT_EPOCH=
WALRUS_MEMORY_EXTEND_EPOCHS=
WALRUS_MEMORY_RENEW_LIMIT=
WALRUS_MEMORY_RENEW_BEFORE_EPOCHS=
WALRUS_CLI_BIN=
WALRUS_CONFIG=
WALRUS_CONTEXT=
WALRUS_WALLET=

# Optional diagnostics/scripts
SIVRAJ_MEMORY_DIAGNOSE_ID=
SIVRAJ_RESET_WALLET=
